class(it, package) ::= <<
package de.flapdoodle.embed.mongo.packageresolver<if(it.package.is)>.<it.package.get><endif>;

<!
import de.flapdoodle.embed.process.config.store.FileSet;
import de.flapdoodle.embed.process.config.store.FileType;
import de.flapdoodle.embed.process.config.store.Package;
import de.flapdoodle.embed.process.distribution.ArchiveType;
import de.flapdoodle.embed.process.distribution.Distribution;
import de.flapdoodle.os.BitSize;
import de.flapdoodle.os.CommonOS;

import java.util.Optional;
!>

public class <it.name> extends AbstractPackageFinder {

	public <it.name>(final Command command) {
		super(command, rules(command));
	}

	private static ImmutablePackageFinderRules rules(final Command command) {
<package.entries:{ pair | <pair.second.entries:{ urlAndVersions |
<if(urlAndVersions.versions.hasDevVersions)>
        PackageFinderRule devRule_<pair.first.variableName><urlAndVersions.index> = PackageFinderRule.builder()
            .match(<matchPackage(pair.first)>
                .andThen(
                    <versionRanges(urlAndVersions.versions.devVersions)>
            ))
            .finder(UrlTemplatePackageFinder.builder()
				.fileSet(fileSet)
				.archiveType(ArchiveType.<urlAndVersions.archiveType>)
				.urlTemplate("<urlAndVersions.url>")
				.isDevVersion(true)
				.build())
			.build();

<endif>
<if(urlAndVersions.versions.hasVersions)>
        PackageFinderRule rule_<pair.first.variableName><urlAndVersions.index> = PackageFinderRule.builder()
            .match(<matchPackage(pair.first)>
                .andThen(
                    <versionRanges(urlAndVersions.versions.versions)>
            ))
            .finder(UrlTemplatePackageFinder.builder()
				.fileSet(fileSet)
				.archiveType(ArchiveType.<urlAndVersions.archiveType>)
				.urlTemplate("<urlAndVersions.url>")
				.build())
			.build();
<endif>
}>}>
    switch (command) {
      case MongoDump:
      case MongoImport:
      case MongoRestore:
        return PackageFinderRules.empty()
            .withRules(
              tools_ubuntu22arm, tools_ubuntu22x64,
              tools_ubuntu20to22arm, tools_ubuntu20to22x64,
              tools_ubuntu1804arm, tools_ubuntu1804x64,
              tools_ubuntu1604arm, tools_ubuntu1604x64
            );
      default:
        return PackageFinderRules.empty()
<package.entries:{ pair |
            .withRules(
                <pair.second.entries:{ urlAndVersions | <if(urlAndVersions.versions.hasDevVersions)>devRule_<pair.first.variableName><urlAndVersions.index><endif><if(urlAndVersions.versions.hasDevVersions && urlAndVersions.versions.hasVersions)>, <endif><if(urlAndVersions.versions.hasVersions)>rule_<pair.first.variableName><urlAndVersions.index><endif>}; separator=", ">
            )}>;
	}
  }
}
>>

matchPackage(package) ::= <<match(BitSize.<package.bitSize>, CPUType.<package.cpuType><package.versions:{ version |, <version.className>.<version>}>)>>
versionRanges(versions) ::= << <versions: {version | <versionRange(version)>}; separator=",\n"> >>
versionRange(version) ::= <<VersionRange.of(<if(version.isExact)>"<version.min>"<else>"<version.min>", "<version.max>"<endif>)>>